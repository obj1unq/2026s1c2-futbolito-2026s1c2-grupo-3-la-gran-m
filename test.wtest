import objetos.*

describe "name" {
  test "description" {
    
	method initialize() {
	
    	// El game no se reinicia en cada test: https://github.com/uqbar-project/wollok/issues/1896
		    
        game.clear()
        game.addVisual(lionel)
        game.addVisual(pelota)
        game.cellSize(40)
        game.width(15)
        game.height(10)
        lionel.position(game.at(3,5))
        pelota.position(game.at(5,5))
    }

    test "lionel se acerca a la pelota y taquea una vez" {

      keyboard.right().onPressDo({lionel.avanzar()})
      keyboard.right().onPressDo({lionel.avanzar()})
      keyboard.t().onPressDo({lionel.tirarTaco()})

      assert.equals(game.at(5,5), lionel.position())
      assert.equals(game.at(3,5), pelota.position())
	  }



  }
}
